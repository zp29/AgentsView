# AgentsView server
AGENTSVIEW_HOST=127.0.0.1
AGENTSVIEW_PORT=4173
AGENTSVIEW_PUBLIC_ORIGIN=
AGENTSVIEW_DATA_DIR=./data
AGENTSVIEW_LOG_LEVEL=info

# Leave blank to let AgentsView generate a strong local access token.
# Never commit a real token.
AGENTSVIEW_ACCESS_TOKEN=
AGENTSVIEW_SESSION_TTL_HOURS=24
AGENTSVIEW_APPROVAL_TTL_MINUTES=10

# Set true only when running behind a reverse proxy you control.
AGENTSVIEW_TRUST_PROXY=false

# Demo mode uses the same state, WebSocket, approval and audit pipeline as real agents.
AGENTSVIEW_DEMO_MODE=true

# Real adapters: auto enables an adapter only when its runtime is available.
CODEX_ENABLED=auto
CODEX_COMMAND=codex
CLAUDE_ENABLED=auto

# Required for Claude Agent SDK tasks. A claude.ai subscription is not an API key.
ANTHROPIC_API_KEY=

# Leave blank to generate data/claude-hook-secret automatically.
# Set explicitly only when the hook secret must be managed externally.
CLAUDE_HOOK_SECRET=
