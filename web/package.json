{
  "name": "agentsview",
  "version": "0.1.0",
  "description": "A mobile-friendly constellation console for Codex and Claude coding agents.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zp29/AgentsView.git"
  },
  "homepage": "https://github.com/zp29/AgentsView#readme",
  "bugs": {
    "url": "https://github.com/zp29/AgentsView/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "node scripts/build.js",
    "start": "node dist/server.js",
    "start:source": "node src/server.js",
    "task": "node src/cli.js task",
    "token": "node src/cli.js token",
    "hooks:print": "node src/cli.js hooks-print",
    "hooks:install": "node scripts/install-hooks.js",
    "test": "node --test --test-reporter=spec",
    "check": "node scripts/check.js"
  },
  "keywords": [
    "codex",
    "claude-code",
    "agent-monitoring",
    "approvals"
  ]
}
